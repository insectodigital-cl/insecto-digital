---
// index.astro - Insecto Digital Homepage — v6
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Insecto Digital — Hub Creativo</title>
  <meta name="description" content="Hub creativo digital. Diseño gráfico, fotografía, video, audio y desarrollo creativo con AI. Santiago, Chile." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --negro: #080808; --verde: #BCFF47; --magenta: #FF3CAC;
      --cyan: #2AFADF; --naranja: #FF6B2B; --violeta: #9B5DFF;
      --blanco: #F5F0E8; --gris: #1A1A1A; --gris2: #2C2C2C;
      --whatsapp: #25D366; --whatsapp-dark: #1da851;
      --font-display: 'Syne', sans-serif; --font-body: 'DM Sans', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--negro);
      color: var(--blanco);
      font-family: var(--font-body);
      font-weight: 300;
      overflow-x: hidden;
      cursor: none;
    }

    /* 🔥 EFECTO BREATHING (NUEVO - SIN ROMPER DISEÑO) */
    @keyframes breathing {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.6; }
    }

    .line-accent,
    .hero-label,
    .section-label,
    .ai-badge {
      animation: breathing 3s ease-in-out infinite;
    }

    /* ================= RESTO ORIGINAL ================= */

    .cursor { width: 12px; height: 12px; background: var(--verde); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); transition: width .2s,height .2s; mix-blend-mode: difference; }
    .cursor-follower { width: 36px; height: 36px; border: 1px solid rgba(188,255,71,.4); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9998; transform: translate(-50%,-50%); transition: all .12s ease-out; }

    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 4rem; mix-blend-mode: difference; }
    .logo { font-family: var(--font-display); font-weight: 800; font-size: 1.1rem; color: var(--blanco); text-decoration: none; letter-spacing: -.02em; }
    .logo span { color: var(--verde); }

    nav ul { list-style: none; display: flex; gap: 2.5rem; align-items: center; }
    nav ul a { color: var(--blanco); text-decoration: none; font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; opacity: .7; transition: opacity .2s; }
    nav ul a:hover { opacity: 1; }

    .nav-cta {
      font-family: var(--font-display); font-weight: 700; font-size: .75rem;
      color: var(--negro) !important; background: var(--whatsapp);
      padding: .5rem 1.25rem; border-radius: 100px;
    }

    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-end; padding: 0 4rem 5rem; position: relative; }

    .hero-label {
      font-size:.7rem;
      letter-spacing:.2em;
      text-transform:uppercase;
      color:var(--verde);
      margin-bottom:1.5rem;
    }

    .hero-title {
      font-family:var(--font-display);
      font-weight:800;
      font-size:clamp(3.2rem,10vw,9rem);
      line-height:.92;
    }

    .line-accent { color: var(--verde); }
    .line-stroke { -webkit-text-stroke:1px var(--blanco); color:transparent }

    .btn-primary {
      background:var(--verde);
      color:var(--negro);
      padding:1rem 2rem;
      border-radius:100px;
      text-decoration:none;
    }

    .section {
      padding:8rem 4rem;
    }

    .section-label {
      font-size:.65rem;
      letter-spacing:.25em;
      text-transform:uppercase;
      color:var(--verde);
      margin-bottom:3rem;
    }

    .ai-badge {
      display:inline-flex;
      background:rgba(155,93,255,.12);
      border:1px solid rgba(155,93,255,.25);
      padding:.4rem 1rem;
      border-radius:100px;
      font-size:.7rem;
      color:var(--violeta);
    }

    footer {
      border-top:1px solid var(--gris2);
      padding:3rem 4rem;
      display:flex;
      justify-content:space-between;
    }

  </style>
</head>

<body>

  <nav>
    <a href="/" class="logo">insecto<span>.</span>digital</a>
  </nav>

  <section class="hero">
    <div class="hero-label">Hub Creativo Digital — Santiago, Chile</div>

    <h1 class="hero-title">
      Creamos<br>
      <span class="line-stroke">mundos</span><br>
      <span class="line-accent">digitales</span>
    </h1>

    <a href="#servicios" class="btn-primary">Ver servicios</a>
  </section>

  <section class="section" id="servicios">
    <div class="section-label">Lo que hacemos</div>
  </section>

  <section class="section">
    <div class="ai-badge">Tecnología de vanguardia</div>
  </section>

  <footer>
    <span>© 2025 Insecto Digital</span>
  </footer>

</body>
</html>
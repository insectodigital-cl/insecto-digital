---
// index.astro - Insecto Digital Homepage — v4
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Insecto Digital — Hub Creativo</title>
  <meta name="description" content="Hub creativo digital. Diseño gráfico, fotografía, video, audio y desarrollo creativo con AI. Santiago, Chile." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --negro: #080808; --verde: #BCFF47; --magenta: #FF3CAC;
      --cyan: #2AFADF; --naranja: #FF6B2B; --violeta: #9B5DFF;
      --blanco: #F5F0E8; --gris: #1A1A1A; --gris2: #2C2C2C;
      --font-display: 'Syne', sans-serif; --font-body: 'DM Sans', sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--negro); color: var(--blanco); font-family: var(--font-body); font-weight: 300; overflow-x: hidden; cursor: none; }

    /* CURSOR — solo desktop */
    .cursor { width: 12px; height: 12px; background: var(--verde); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); transition: width .2s, height .2s; mix-blend-mode: difference; }
    .cursor-follower { width: 36px; height: 36px; border: 1px solid rgba(188,255,71,.4); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9998; transform: translate(-50%,-50%); transition: all .12s ease-out; }

    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 4rem; mix-blend-mode: difference; }
    .logo { font-family: var(--font-display); font-weight: 800; font-size: 1.1rem; color: var(--blanco); text-decoration: none; letter-spacing: -.02em; }
    .logo span { color: var(--verde); }
    nav ul { list-style: none; display: flex; gap: 2.5rem; }
    nav ul a { color: var(--blanco); text-decoration: none; font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; opacity: .7; transition: opacity .2s; }
    nav ul a:hover { opacity: 1; }
    .nav-cta { font-family: var(--font-display); font-weight: 700; font-size: .75rem; color: var(--negro) !important; background: var(--verde); padding: .5rem 1.25rem; border-radius: 100px; opacity: 1 !important; }

    /* HERO */
    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-end; padding: 0 4rem 5rem; position: relative; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; z-index: 0; }
    .blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: .18; animation: float 8s ease-in-out infinite; }
    .blob-1 { width: 600px; height: 600px; background: var(--verde); top: -100px; right: -100px; }
    .blob-2 { width: 400px; height: 400px; background: var(--magenta); bottom: 100px; left: 10%; animation-delay: -3s; }
    .blob-3 { width: 300px; height: 300px; background: var(--cyan); top: 30%; left: 40%; animation-delay: -6s; }
    .blob-4 { width: 250px; height: 250px; background: var(--violeta); top: 60%; right: 20%; animation-delay: -4s; }
    @keyframes float { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(30px,-20px) scale(1.05)} 66%{transform:translate(-20px,15px) scale(.95)} }
    .noise-overlay { position: absolute; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E"); opacity: .035; pointer-events: none; }
    .hero-label { font-size: .7rem; letter-spacing: .2em; text-transform: uppercase; color: var(--verde); margin-bottom: 1.5rem; position: relative; z-index: 1; display: flex; align-items: center; gap: .75rem; }
    .hero-label::before { content: ''; display: block; width: 32px; height: 1px; background: var(--verde); }
    .hero-title { font-family: var(--font-display); font-weight: 800; font-size: clamp(3.2rem,10vw,9rem); line-height: .92; letter-spacing: -.04em; position: relative; z-index: 1; max-width: 100%; overflow-wrap: break-word; }
    .hero-title .line-accent { color: var(--verde); }
    .hero-title .line-stroke { -webkit-text-stroke: 1px var(--blanco); color: transparent; }
    .hero-bottom { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 4rem; position: relative; z-index: 1; }
    .hero-desc { max-width: 340px; font-size: 1rem; line-height: 1.6; opacity: .65; }
    .hero-actions { display: flex; gap: 1rem; align-items: center; }
    .btn-primary { font-family: var(--font-display); font-weight: 700; font-size: .85rem; background: var(--verde); color: var(--negro); padding: 1rem 2rem; border-radius: 100px; text-decoration: none; letter-spacing: .05em; text-transform: uppercase; transition: transform .2s, box-shadow .2s; border: none; cursor: pointer; display: inline-block; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 40px rgba(188,255,71,.35); }
    .btn-ghost { font-size: .8rem; color: var(--blanco); text-decoration: none; letter-spacing: .08em; text-transform: uppercase; opacity: .6; display: flex; align-items: center; gap: .5rem; transition: opacity .2s; }
    .btn-ghost:hover { opacity: 1; }
    .btn-ghost svg { transition: transform .2s; }
    .btn-ghost:hover svg { transform: translateX(4px); }
    .hero-scroll { position: absolute; right: 4rem; bottom: 5rem; writing-mode: vertical-rl; font-size: .65rem; letter-spacing: .2em; text-transform: uppercase; opacity: .35; z-index: 1; display: flex; align-items: center; gap: .75rem; }
    .hero-scroll::after { content: ''; width: 1px; height: 60px; background: var(--blanco); opacity: .3; animation: scrollLine 2s ease-in-out infinite; }
    @keyframes scrollLine { 0%,100%{transform:scaleY(1);opacity:.3} 50%{transform:scaleY(.5);opacity:.1} }

    /* TICKER */
    .ticker { border-top: 1px solid var(--gris2); border-bottom: 1px solid var(--gris2); padding: 1rem 0; overflow: hidden; white-space: nowrap; }
    .ticker-inner { display: inline-flex; animation: ticker 30s linear infinite; }
    .ticker-item { display: inline-flex; align-items: center; gap: 1.5rem; padding: 0 2rem; font-family: var(--font-display); font-weight: 700; font-size: .8rem; letter-spacing: .1em; text-transform: uppercase; opacity: .4; }
    .ticker-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--verde); flex-shrink: 0; }
    .ticker-dot.mg{background:var(--magenta)} .ticker-dot.cy{background:var(--cyan)} .ticker-dot.na{background:var(--naranja)} .ticker-dot.vi{background:var(--violeta)}
    @keyframes ticker { from{transform:translateX(0)} to{transform:translateX(-50%)} }

    /* SECCIONES */
    .section { padding: 8rem 4rem; }
    .section-label { font-size: .65rem; letter-spacing: .25em; text-transform: uppercase; color: var(--verde); margin-bottom: 3rem; display: flex; align-items: center; gap: .75rem; }
    .section-label::before { content: ''; width: 24px; height: 1px; background: var(--verde); }
    .section-title { font-family: var(--font-display); font-weight: 800; font-size: clamp(2rem,5vw,4.5rem); line-height: 1.05; letter-spacing: -.03em; margin-bottom: 5rem; max-width: 700px; }

    /* SERVICIOS */
    .services-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; border: 1px solid var(--gris2); }
    .service-card { padding: 3rem 2.5rem; border-right: 1px solid var(--gris2); position: relative; overflow: hidden; transition: background .3s; }
    .service-card:last-child { border-right: none; }
    .service-card::before { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: var(--verde); transform: scaleX(0); transform-origin: left; transition: transform .4s ease; }
    .service-card:hover::before { transform: scaleX(1); }
    .service-card:hover { background: var(--gris); }
    .service-num { font-family: var(--font-display); font-size: .65rem; letter-spacing: .15em; color: var(--verde); margin-bottom: 2rem; opacity: .8; }
    .service-icon { font-size: 2.5rem; margin-bottom: 1.5rem; display: block; }
    .service-name { font-family: var(--font-display); font-weight: 700; font-size: 1.25rem; margin-bottom: 1rem; letter-spacing: -.02em; }
    .service-desc { font-size: .9rem; line-height: 1.65; opacity: .55; }
    .service-tags { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: .4rem; }
    .tag { font-size: .65rem; letter-spacing: .08em; text-transform: uppercase; border: 1px solid var(--gris2); padding: .3rem .7rem; border-radius: 100px; opacity: .5; transition: border-color .2s, opacity .2s; }
    .service-card:hover .tag { border-color: var(--verde); opacity: .8; }

    /* MANIFIESTO */
    .manifesto { padding: 8rem 4rem; background: var(--verde); color: var(--negro); position: relative; overflow: hidden; }
    .manifesto-bg-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-family: var(--font-display); font-weight: 800; font-size: 25vw; color: rgba(0,0,0,.06); white-space: nowrap; pointer-events: none; user-select: none; }
    .manifesto-content { position: relative; z-index: 1; max-width: 1000px; }
    .manifesto-label { font-size: .65rem; letter-spacing: .25em; text-transform: uppercase; margin-bottom: 2rem; opacity: .6; display: flex; align-items: center; gap: .75rem; }
    .manifesto-label::before { content: ''; width: 24px; height: 1px; background: var(--negro); }
    .manifesto-title { font-family: var(--font-display); font-weight: 800; font-size: clamp(2rem,5vw,5rem); line-height: 1.05; letter-spacing: -.03em; }
    .manifesto-title em { font-style: italic; font-weight: 400; }

    /* VISUAL */
    .visual-section { padding: 8rem 4rem; background: var(--gris); }
    .visual-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
    .visual-card { background: var(--negro); border: 1px solid var(--gris2); border-radius: 4px; overflow: hidden; transition: transform .3s, box-shadow .3s; }
    .visual-card:hover { transform: translateY(-6px); box-shadow: 0 24px 60px rgba(0,0,0,.5); }
    .visual-card-header { height: 180px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
    .decoration { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; opacity: .12; }
    .aperture { width: 120px; height: 120px; border: 1px solid var(--naranja); border-radius: 50%; position: relative; }
    .aperture::before,.aperture::after { content: ''; position: absolute; inset: 15px; border: 1px solid var(--naranja); border-radius: 50%; }
    .aperture::after { inset: 35px; }
    .play-deco { width: 0; height: 0; border-left: 50px solid var(--magenta); border-top: 30px solid transparent; border-bottom: 30px solid transparent; margin-left: 10px; }
    .waveform { display: flex; align-items: center; gap: 3px; }
    .waveform span { width: 3px; border-radius: 2px; background: var(--cyan); animation: wave 1.2s ease-in-out infinite; }
    .waveform span:nth-child(1){height:20px}.waveform span:nth-child(2){height:40px;animation-delay:.1s}.waveform span:nth-child(3){height:60px;animation-delay:.2s}.waveform span:nth-child(4){height:80px;animation-delay:.3s}.waveform span:nth-child(5){height:100px;animation-delay:.4s}.waveform span:nth-child(6){height:80px;animation-delay:.5s}.waveform span:nth-child(7){height:60px;animation-delay:.6s}.waveform span:nth-child(8){height:40px;animation-delay:.7s}.waveform span:nth-child(9){height:20px;animation-delay:.8s}
    @keyframes wave { 0%,100%{transform:scaleY(1)} 50%{transform:scaleY(.4)} }
    .big-icon { font-size: 3.5rem; position: relative; z-index: 1; }
    .visual-card-body { padding: 2rem 2.5rem 2.5rem; }
    .visual-card-num { font-family: var(--font-display); font-size: .65rem; letter-spacing: .15em; color: var(--naranja); margin-bottom: .75rem; opacity: .8; }
    .visual-card-num.m{color:var(--magenta)} .visual-card-num.c{color:var(--cyan)}
    .visual-card-name { font-family: var(--font-display); font-weight: 700; font-size: 1.3rem; margin-bottom: .75rem; letter-spacing: -.02em; }
    .visual-card-desc { font-size: .9rem; line-height: 1.6; opacity: .55; }
    .visual-card-tags { margin-top: 1.5rem; display: flex; flex-wrap: wrap; gap: .4rem; }

    /* AI */
    .ai-section { padding: 8rem 4rem; position: relative; overflow: hidden; }
    .ai-section::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 20% 50%,rgba(155,93,255,.1) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(42,250,223,.07) 0%,transparent 50%),radial-gradient(ellipse at 60% 80%,rgba(255,60,172,.07) 0%,transparent 50%); pointer-events: none; }
    .ai-inner { position: relative; z-index: 1; }
    .ai-badge { display: inline-flex; align-items: center; gap: .5rem; background: rgba(155,93,255,.12); border: 1px solid rgba(155,93,255,.25); padding: .4rem 1rem; border-radius: 100px; font-size: .7rem; letter-spacing: .15em; text-transform: uppercase; color: var(--violeta); margin-bottom: 2rem; }
    .ai-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--violeta); animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.7)} }
    .ai-title { font-family: var(--font-display); font-weight: 800; font-size: clamp(2rem,6vw,5.5rem); line-height: 1; letter-spacing: -.04em; margin-bottom: 1.5rem; }
    .ai-title .grad { background: linear-gradient(90deg,var(--violeta),var(--cyan),var(--magenta)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .ai-subtitle { font-size: 1.05rem; opacity: .6; line-height: 1.6; max-width: 520px; margin-bottom: 4rem; }
    .ai-tools-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
    .ai-tool { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 16px; padding: 2rem; transition: all .3s; position: relative; overflow: hidden; }
    .ai-tool::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg,rgba(155,93,255,.07),transparent); opacity: 0; transition: opacity .3s; }
    .ai-tool:hover::before { opacity: 1; }
    .ai-tool:hover { border-color: rgba(155,93,255,.3); transform: translateY(-4px); }
    .ai-tool-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }
    .ai-tool-name { font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; margin-bottom: .6rem; letter-spacing: -.02em; }
    .ai-tool-desc { font-size: .85rem; opacity: .5; line-height: 1.55; }
    .ai-examples { margin-top: 1rem; display: flex; flex-wrap: wrap; gap: .35rem; }
    .ai-example { font-size: .6rem; letter-spacing: .08em; text-transform: uppercase; background: rgba(155,93,255,.1); border: 1px solid rgba(155,93,255,.2); color: var(--violeta); padding: .25rem .6rem; border-radius: 100px; }

    /* PROCESO */
    .process { padding: 8rem 4rem; }
    .process-item { display: grid; grid-template-columns: 80px 1fr 1fr; gap: 2rem; align-items: center; padding: 2.5rem 0; border-bottom: 1px solid var(--gris2); transition: all .3s; }
    .process-item:hover { padding-left: 1rem; }
    .process-item:hover .process-num { color: var(--verde); }
    .process-num { font-family: var(--font-display); font-weight: 800; font-size: 3rem; color: var(--gris2); letter-spacing: -.05em; transition: color .3s; }
    .process-name { font-family: var(--font-display); font-weight: 700; font-size: 1.5rem; letter-spacing: -.02em; }
    .process-desc { font-size: .9rem; line-height: 1.6; opacity: .5; }

    /* COMUNIDAD */
    .community { padding: 8rem 4rem; background: var(--gris); }
    .community-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
    .community-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--gris2); }
    .stat { background: var(--gris); padding: 2.5rem; }
    .stat-num { font-family: var(--font-display); font-weight: 800; font-size: 3.5rem; letter-spacing: -.04em; color: var(--verde); line-height: 1; margin-bottom: .5rem; }
    .stat-label { font-size: .8rem; opacity: .5; line-height: 1.4; }

    /* CTA */
    .cta-section { padding: 10rem 4rem; text-align: center; position: relative; overflow: hidden; }
    .cta-section::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 600px; height: 600px; background: radial-gradient(circle,rgba(188,255,71,.08) 0%,transparent 70%); pointer-events: none; }
    .cta-title { font-family: var(--font-display); font-weight: 800; font-size: clamp(2.5rem,7vw,7rem); line-height: .95; letter-spacing: -.04em; margin-bottom: 2.5rem; position: relative; z-index: 1; }
    .cta-title span { color: var(--verde); }
    .cta-subtitle { font-size: 1.1rem; opacity: .5; max-width: 450px; margin: 0 auto 3rem; line-height: 1.6; position: relative; z-index: 1; }
    .cta-btn { font-family: var(--font-display); font-weight: 700; font-size: 1rem; color: var(--negro); background: var(--verde); padding: 1.1rem 2.5rem; border-radius: 100px; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: .6rem; transition: transform .2s, box-shadow .2s; position: relative; z-index: 1; }
    .cta-btn:hover { transform: translateY(-3px); box-shadow: 0 16px 60px rgba(188,255,71,.3); }

    /* MODAL */
    .modal-overlay { position: fixed; inset: 0; background: rgba(8,8,8,.88); backdrop-filter: blur(10px); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 1rem; opacity: 0; pointer-events: none; transition: opacity .3s; }
    .modal-overlay.active { opacity: 1; pointer-events: all; }
    .modal { background: var(--gris); border: 1px solid var(--gris2); border-radius: 12px; padding: 3rem; width: 100%; max-width: 560px; position: relative; transform: translateY(20px); transition: transform .3s; max-height: 90vh; overflow-y: auto; }
    .modal-overlay.active .modal { transform: translateY(0); }
    .modal-close { position: absolute; top: 1.5rem; right: 1.5rem; background: none; border: none; cursor: pointer; color: var(--blanco); opacity: .4; font-size: 1.5rem; line-height: 1; transition: opacity .2s; }
    .modal-close:hover { opacity: 1; }
    .modal-label { font-size: .65rem; letter-spacing: .25em; text-transform: uppercase; color: var(--verde); margin-bottom: 1.5rem; display: flex; align-items: center; gap: .75rem; }
    .modal-label::before { content: ''; width: 24px; height: 1px; background: var(--verde); }
    .modal-title { font-family: var(--font-display); font-weight: 800; font-size: 2rem; letter-spacing: -.03em; margin-bottom: 2rem; line-height: 1.1; }
    .form-group { margin-bottom: 1.25rem; }
    .form-group label { display: block; font-size: .7rem; letter-spacing: .1em; text-transform: uppercase; opacity: .5; margin-bottom: .5rem; }
    .form-group input,.form-group textarea,.form-group select { width: 100%; background: rgba(255,255,255,.04); border: 1px solid var(--gris2); border-radius: 6px; padding: .85rem 1rem; color: var(--blanco); font-family: var(--font-body); font-size: .95rem; font-weight: 300; transition: border-color .2s; outline: none; -webkit-appearance: none; }
    .form-group input:focus,.form-group textarea:focus,.form-group select:focus { border-color: var(--verde); }
    .form-group textarea { resize: vertical; min-height: 110px; }
    .form-group select option { background: var(--gris); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .btn-submit { width: 100%; font-family: var(--font-display); font-weight: 700; font-size: .9rem; letter-spacing: .05em; text-transform: uppercase; background: var(--verde); color: var(--negro); border: none; border-radius: 100px; padding: 1rem; margin-top: .5rem; cursor: pointer; transition: transform .2s, box-shadow .2s; }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(188,255,71,.3); }
    .btn-submit:disabled { opacity: .6; transform: none; cursor: not-allowed; }
    .form-success { text-align: center; padding: 2rem 0; display: none; }
    .success-icon { font-size: 3rem; margin-bottom: 1rem; display: block; }
    .form-success h3 { font-family: var(--font-display); font-size: 1.5rem; margin-bottom: .75rem; }
    .form-success p { opacity: .6; font-size: .95rem; line-height: 1.6; }
    .form-error { background: rgba(255,60,172,.1); border: 1px solid rgba(255,60,172,.3); border-radius: 6px; padding: .75rem 1rem; font-size: .85rem; color: var(--magenta); margin-bottom: 1rem; display: none; }

    /* FOOTER */
    footer { border-top: 1px solid var(--gris2); padding: 3rem 4rem; display: flex; justify-content: space-between; align-items: center; }
    .footer-logo { font-family: var(--font-display); font-weight: 800; font-size: 1rem; color: var(--blanco); text-decoration: none; }
    .footer-logo span { color: var(--verde); }
    .footer-links { display: flex; gap: 2rem; list-style: none; }
    .footer-links a { color: var(--blanco); text-decoration: none; font-size: .75rem; opacity: .4; letter-spacing: .08em; text-transform: uppercase; transition: opacity .2s; }
    .footer-links a:hover { opacity: 1; }
    .footer-copy { font-size: .7rem; opacity: .25; }

    /* REVEAL */
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity .7s ease, transform .7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1{transition-delay:.1s} .reveal-delay-2{transition-delay:.2s} .reveal-delay-3{transition-delay:.3s} .reveal-delay-4{transition-delay:.4s}

    /* ═══════════ RESPONSIVE MÓVIL ═══════════ */
    @media (max-width: 900px) {
      body { cursor: auto; }
      .cursor,.cursor-follower { display: none; }
      nav { padding: 1.2rem 1.5rem; }
      nav ul { display: none; }
      .hero { padding: 0 1.5rem 4rem; }
      .hero-title { font-size: clamp(2.6rem,11vw,4rem); overflow-wrap: break-word; word-break: break-word; }
      .hero-bottom { flex-direction: column; align-items: flex-start; gap: 2rem; }
